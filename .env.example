# ============ APPLICATION ============
FLASK_ENV=production
SECRET_KEY=your-super-secret-key-change-this-please-123456789
DEBUG=False
PORT=5000
APP_NAME=UltimateMegaApp
TIMEZONE=UTC

# ============ DATABASES ============
DATABASE_URL=postgresql://postgres:password@db:5432/ultimatemegaapp
REDIS_URL=redis://redis:6379/0
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ============ EMAIL (SMTP) ============
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@ultimatemegaapp.com
EMAIL_FROM_NAME=Ultimate Mega App

# ============ SMS (Twilio) ============
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ============ APIs ============
OPENWEATHER_API_KEY=your_openweather_api_key
GOOGLE_API_KEY=your_google_api_key
GOOGLE_CSE_ID=your_search_engine_id
HUGGINGFACE_API_KEY=your_huggingface_api_key
OPENAI_API_KEY=your_openai_api_key
DEEPGRAM_API_KEY=your_deepgram_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key
REPLICATE_API_TOKEN=your_replicate_token

# ============ PAYMENTS ============
STRIPE_PUBLIC_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret

# ============ SOCIAL LOGIN ============
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ============ MONITORING ============
SENTRY_DSN=https://your-dsn@sentry.io/project
ELASTICSEARCH_URL=http://localhost:9200
PROMETHEUS_PORT=9090

# ============ ADMIN ============
ADMIN_EMAIL=admin@ultimatemegaapp.com
ADMIN_PASSWORD=Admin123!@#
ADMIN_USERNAME=superadmin

# ============ FEATURE FLAGS ============
ENABLE_AI_FEATURES=true
ENABLE_PAYMENTS=true
ENABLE_SOCIAL_LOGIN=true
ENABLE_WEBHOOKS=true
ENABLE_ADVANCED_ANALYTICS=true

# ============ LIMITS ============
RATE_LIMIT_DEFAULT=1000 per day,100 per hour
MAX_UPLOAD_SIZE=104857600
MAX_AI_CALLS_PER_DAY=100
MAX_FILE_UPLOADS=50